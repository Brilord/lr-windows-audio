<Window x:Class="BalanceDock.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BalanceDock"
        Height="330"
        Width="420"
        MinHeight="330"
        MinWidth="380"
        ResizeMode="CanMinimize"
        Background="{StaticResource WindowBackgroundBrush}"
        Foreground="{StaticResource TextBrush}"
        SourceInitialized="OnSourceInitialized"
        Closing="OnClosing">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#26313B" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush" Value="#3A4652" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style TargetType="Slider">
            <Setter Property="Minimum" Value="-100" />
            <Setter Property="Maximum" Value="100" />
            <Setter Property="TickFrequency" Value="5" />
            <Setter Property="IsSnapToTickEnabled" Value="True" />
        </Style>
    </Window.Resources>

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" LastChildFill="True">
            <TextBlock Text="BalanceDock"
                       FontSize="24"
                       FontWeight="SemiBold" />
            <Button DockPanel.Dock="Right"
                    Content="Reset"
                    Click="OnResetClicked" />
        </DockPanel>

        <Border Grid.Row="1"
                Margin="0,16,0,0"
                Padding="12"
                Background="{StaticResource PanelBrush}"
                BorderBrush="#26313B"
                BorderThickness="1"
                CornerRadius="8">
            <StackPanel>
                <TextBlock Text="Active output"
                           Foreground="{StaticResource SubtleTextBrush}"
                           FontSize="12" />
                <TextBlock x:Name="DeviceNameText"
                           Margin="0,4,0,0"
                           TextWrapping="Wrap"
                           FontSize="14"
                           FontWeight="SemiBold" />
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="2" Margin="0,22,0,0">
            <Grid>
                <TextBlock Text="L"
                           HorizontalAlignment="Left"
                           Foreground="{StaticResource SubtleTextBrush}" />
                <TextBlock Text="Center"
                           HorizontalAlignment="Center"
                           Foreground="{StaticResource SubtleTextBrush}" />
                <TextBlock Text="R"
                           HorizontalAlignment="Right"
                           Foreground="{StaticResource SubtleTextBrush}" />
            </Grid>
            <Slider x:Name="BalanceSlider"
                    Margin="0,10,0,0"
                    Height="44"
                    ValueChanged="OnBalanceSliderChanged" />
        </StackPanel>

        <Grid Grid.Row="3" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="LeftPercentText"
                       Grid.Column="0"
                       FontSize="24"
                       FontWeight="SemiBold" />
            <TextBlock x:Name="RightPercentText"
                       Grid.Column="1"
                       HorizontalAlignment="Right"
                       FontSize="24"
                       FontWeight="SemiBold" />
        </Grid>

        <TextBlock x:Name="StatusText"
                   Grid.Row="4"
                   Margin="0,16,0,0"
                   Foreground="{StaticResource SubtleTextBrush}"
                   TextWrapping="Wrap"
                   FontSize="12" />
    </Grid>
</Window>
